<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclude filter for CI Gate 3 (zero high/critical).
  Excludes Medium/Low patterns acceptable here: EI_EXPOSE_REP, EI_EXPOSE_REP2,
  UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR (MapStruct/Lombok), DM_CONVERT_CASE.
-->
<FindBugsFilter>
    <Match><Bug pattern="EI_EXPOSE_REP"/></Match>
    <Match><Bug pattern="EI_EXPOSE_REP2"/></Match>
    <Match><Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/></Match>
    <Match><Bug pattern="DM_CONVERT_CASE"/></Match>
</FindBugsFilter>
